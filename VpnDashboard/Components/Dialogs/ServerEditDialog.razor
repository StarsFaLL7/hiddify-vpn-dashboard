@* Диалог создания/редактирования сервера Hiddify. Возвращает заполненную сущность. *@

<MudDialog>
    <DialogContent>
        <MudForm @ref="_form">
            <MudTextField @bind-Value="Model.Name" Label="Имя" Required RequiredError="Укажите имя"
                          HelperText="Человекочитаемое, например NL-01" />
            <MudTextField @bind-Value="Model.Domain" Label="Домен" Required RequiredError="Укажите домен"
                          HelperText="Без https:// и слешей, например vpn.example.com" />
            <MudTextField @bind-Value="Model.AdminProxyPath" Label="Proxy Path (Admins)" Required
                          RequiredError="Укажите admin proxy path"
                          HelperText="Используется для admin-API" />
            <MudTextField @bind-Value="Model.ClientProxyPath" Label="Proxy Path (Clients)" Required
                          RequiredError="Укажите client proxy path"
                          HelperText="Используется для subscription-ссылок витрины" />
            <MudTextField @bind-Value="Model.AdminUuid" Label="Admin UUID (Hiddify-API-Key)" Required
                          RequiredError="Укажите admin UUID" />
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Отмена</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Save">Сохранить</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter] public HiddifyServer Model { get; set; } = new();

    private MudForm _form = null!;

    private async Task Save()
    {
        await _form.ValidateAsync();
        if (!_form.IsValid)
            return;

        Model.Domain = Model.Domain.Trim();
        Model.AdminProxyPath = Model.AdminProxyPath.Trim('/', ' ');
        Model.ClientProxyPath = Model.ClientProxyPath.Trim('/', ' ');
        Model.AdminUuid = Model.AdminUuid.Trim();
        MudDialog.Close(DialogResult.Ok(Model));
    }

    private void Cancel() => MudDialog.Cancel();
}
