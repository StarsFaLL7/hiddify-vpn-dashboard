# Пример .env. Обычно его создаёт deploy.sh автоматически — заполнять вручную нужно,
# только если разворачиваете без скрипта. .env в гит не коммитится.

# Домен сервиса (A-запись должна указывать на этот сервер). Caddy по нему получит TLS.
DOMAIN=vpn.example.com

# Секретный путь админки: два GUID-сегмента. Сгенерируйте свои:
#   cat /proc/sys/kernel/random/uuid   (дважды)
Admin__SecretPathSegment1=00000000-0000-4000-8000-000000000001
Admin__SecretPathSegment2=00000000-0000-4000-8000-000000000002

# Хеш и соль пароля администратора (base64). Сгенерировать:
#   docker compose run --rm --no-deps vpndashboard hash-password "ВАШ_ПАРОЛЬ"
Admin__PasswordHash=
Admin__PasswordSalt=

# Необязательно: параметры фонового пинга.
# Ping__IntervalMinutes=5
# Ping__TimeoutSeconds=8
# Ping__Enabled=true
